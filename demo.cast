[23.755, "o", "pct_status: {\r\n    name:        \"Container Status\"\r\n    description: \"Check LXC container status\"\r\n    command:     \"ssh pve-node1 'pct status 100'\"\r\n    category:    \"monitor\"\r\n    idempotent:  true\r\n}\r\npct_console: {\r\n    name:        \"Container Console\"\r\n    description: \"Attach to LXC container console\"\r\n    command:     \"ssh -t pve-node1 'pct enter 100'\"\r\n    category:    \"connect\"\r\n}\r\npct_logs: {\r\n    name:        \"Container Logs\"\r\n    description: \"View LXC container journal logs\"\r\n    command:     \"ssh pve-node1 'pct exec 100 -- journalctl -n 100'\"\r\n    category:    \"info\"\r\n    idempotent:  true\r\n}\r\n"]
