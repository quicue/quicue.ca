[37.054, "o", "{\r\n    \"@context\": {\r\n        \"@base\": \"https://infra.example.com/resources/\",\r\n        \"APIServer\": \"quicue:APIServer\",\r\n        \"AudiobookLibrary\": \"quicue:AudiobookLibrary\",\r\n        \"AuthServer\": \"quicue:AuthServer\",\r\n        \"AvailabilityZone\": \"quicue:AvailabilityZone\",\r\n        \"Bastion\": \"quicue:Bastion\",\r\n        \"CIJob\": \"quicue:CIJob\",\r\n        \"CIPipeline\": \"quicue:CIPipeline\",\r\n        \"CIRunner\": \"quicue:CIRunner\",\r\n        \"CIStage\": \"quicue:CIStage\",\r\n        \"CacheCluster\": \"quicue:CacheCluster\",\r\n        \"ComposeStack\": \"quicue:ComposeStack\",\r\n        \"ContainerRegistry\": \"quicue:ContainerRegistry\",\r\n        \"CriticalInfra\": \"quicue:CriticalInfra\",\r\n        \"DNSServer\": \"quicue:DNSServer\",\r\n        \"Database\": \"quicue:Database\",\r\n        \"DevelopmentWorkstation\": \"quicue:DevelopmentWorkstation\",\r\n        \"DockerContainer\": \"quicue:DockerContainer\",\r\n        \"DockerHost\": \"quicue:DockerHost\",\r\n        \"EbookLibrary\": \"quicue:EbookLibrary\",\r\n        \"EdgeNode\": \"quicue:EdgeNode\",\r\n        \"GPUCompute\": \"quicue:GPUCompute\",\r\n        \"HomeAutomation\": \"quicue:HomeAutomation\",\r\n        \"KubernetesCluster\": \"quicue:KubernetesCluster\",\r\n        \"KubernetesService\": \"quicue:KubernetesService\",\r\n        \"LXCContainer\": \"quicue:LXCContainer\",\r\n        \"LoadBalancer\": \"quicue:LoadBalancer\",\r\n        \"LogAggregator\": \"quicue:LogAggregator\",\r\n"]
[38.554, "o", "\r\n\u001b[1;34m# 727 pre-computed endpoints. No server. Just files.\u001b[0m\r\n"]
